{
  "name": "blazor-media-queries",
  "version": "1.0.0",
  "description": "Blazor Server application with Tailwind CSS and DaisyUI",
  "scripts": {
    "build:css": "npx tailwindcss -i ./wwwroot/css/tailwind.input.css -o ./wwwroot/css/tailwind.output.css",
    "watch:css": "npx tailwindcss -i ./wwwroot/css/tailwind.input.css -o ./wwwroot/css/tailwind.output.css --watch",
    "build:css:prod": "npx tailwindcss -i ./wwwroot/css/tailwind.input.css -o ./wwwroot/css/tailwind.output.css --minify"
  },
  "keywords": [
    "blazor",
    "tailwindcss",
    "daisyui",
    "responsive-design"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "daisyui": "^4.12.14",
    "tailwindcss": "^3.4.0"
  }
}
