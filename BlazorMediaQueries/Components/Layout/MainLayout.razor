@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- Mobile sidebar overlay -->
@if (_sidebarOpen)
{
    <div class="fixed inset-0 z-20 bg-black/50 md:hidden" @onclick="CloseSidebar"></div>
}

<!-- Sidebar -->
<aside style="background: linear-gradient(to bottom, var(--sidebar-from), var(--sidebar-to))"
       class="fixed inset-y-0 left-0 z-30 w-64 flex flex-col transform transition-transform duration-300 ease-in-out @(_sidebarOpen ? "translate-x-0" : "-translate-x-full") md:translate-x-0">
    <NavMenu />
</aside>

<!-- Main content area -->
<div class="md:ml-64 min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col transition-colors duration-200">

    <!-- Top bar -->
    <header class="sticky top-0 z-10 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 h-14 flex items-center px-4 gap-3 transition-colors duration-200">

        <!-- Hamburger (mobile only) -->
        <button @onclick="ToggleSidebar"
                class="md:hidden p-2 rounded-lg text-slate-500 hover:text-slate-700 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-700 transition-colors"
                aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <div class="flex-1"></div>

        <!-- Palette swatches -->
        <div class="flex items-center gap-1.5" title="Select colour palette">
            @foreach (var p in _palettes)
            {
                <button @onclick="() => SetPalette(p.Key)"
                        style="background-color: @p.AccentColor"
                        class="w-5 h-5 rounded-full border-2 transition-all @(_palette == p.Key ? "border-slate-700 dark:border-white scale-110" : "border-transparent opacity-60 hover:opacity-100 hover:scale-105")"
                        title="@p.Name palette">
                </button>
            }
        </div>

        <!-- Divider -->
        <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>

        <!-- Dark mode toggle -->
        <button @onclick="ToggleDarkMode"
                class="p-2 rounded-lg text-slate-500 hover:text-slate-700 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-700 transition-colors"
                aria-label="Toggle dark mode"
                title="@(_darkMode ? "Switch to light mode" : "Switch to dark mode")">
            @if (_darkMode)
            {
                <!-- Sun icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
            }
            else
            {
                <!-- Moon icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
                </svg>
            }
        </button>

        <a href="https://learn.microsoft.com/aspnet/core/" target="_blank"
           class="text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            About
        </a>
    </header>

    <!-- Page content -->
    <main class="flex-1 p-4 md:p-8">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet class="hidden fixed bottom-0 left-0 w-full z-[1000] bg-yellow-100 text-black px-5 py-2.5 shadow-[0_-1px_2px_rgba(0,0,0,0.2)]" style="color-scheme: light only;">
    An unhandled error has occurred.
    <a href="." class="reload underline">Reload</a>
    <span class="dismiss cursor-pointer absolute right-3 top-2">🗙</span>
</div>

@code {
    private record PaletteOption(string Key, string Name, string AccentColor);

    private static readonly PaletteOption[] _palettes =
    [
        new("default", "Default", "#4f46e5"),
        new("peach",   "Peach",   "#dd2251"),
        new("cdph",    "CDPH",    "#0091ff"),
        new("blues",   "Blues",   "#3b22dd"),
    ];

    private bool _sidebarOpen;
    private bool _darkMode;
    private string _palette = "default";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _darkMode = await JS.InvokeAsync<bool>("darkMode.isDark");
            _palette  = await JS.InvokeAsync<string>("palette.get");
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _sidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private async Task ToggleDarkMode()
    {
        _darkMode = !_darkMode;
        await JS.InvokeVoidAsync("darkMode.set", _darkMode);
    }

    private async Task SetPalette(string palette)
    {
        _palette = palette;
        await JS.InvokeVoidAsync("palette.set", palette);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
