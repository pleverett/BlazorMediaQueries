@inherits LayoutComponentBase

<div class="relative flex flex-col md:flex-row">
    <div class="bg-gradient-to-b from-[rgb(5,39,103)] to-[#3a0647] md:w-[250px] md:h-screen md:sticky md:top-0">
        <NavMenu />
    </div>

    <main class="flex-1">
        <div class="bg-neutral-100 border-b border-neutral-300 flex items-center justify-end md:justify-end h-14 px-4 md:sticky md:top-0 md:z-10 md:px-8 md:pr-6">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="whitespace-nowrap ml-6 md:ml-6 no-underline hover:underline overflow-hidden text-ellipsis">About</a>
        </div>

        <article class="px-4 md:px-8 md:pr-6">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet class="hidden fixed bottom-0 left-0 w-full z-[1000] bg-yellow-100 text-black px-5 py-2.5 shadow-[0_-1px_2px_rgba(0,0,0,0.2)]" style="color-scheme: light only;">
    An unhandled error has occurred.
    <a href="." class="reload underline">Reload</a>
    <span class="dismiss cursor-pointer absolute right-3 top-2">🗙</span>
</div>
