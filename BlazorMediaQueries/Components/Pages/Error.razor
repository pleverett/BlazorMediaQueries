@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="py-8 max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-rose-600 dark:text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <div>
            <h1 class="text-xl font-bold text-slate-900 dark:text-white">An error occurred</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400">An unhandled error occurred while processing your request.</p>
        </div>
    </div>

    @if (ShowRequestId)
    {
        <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm p-4 mb-6">
            <p class="text-sm text-slate-600 dark:text-slate-300">
                <span class="font-semibold text-slate-900 dark:text-white">Request ID:</span>
                <code class="ml-2 font-mono text-xs bg-slate-100 dark:bg-slate-700 px-2 py-0.5 rounded">@RequestId</code>
            </p>
        </div>
    }

    <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/50 rounded-xl p-5">
        <h3 class="font-semibold text-amber-900 dark:text-amber-300 mb-2">Development Mode</h3>
        <p class="text-sm text-amber-800 dark:text-amber-400 mb-3">
            Switch to the <strong>Development</strong> environment to see detailed error information.
        </p>
        <p class="text-sm text-amber-800 dark:text-amber-400">
            <strong>Never enable Development in production</strong> — it may expose sensitive details to end users.
            Set <code class="font-mono text-xs bg-amber-100 dark:bg-amber-900/40 px-1.5 py-0.5 rounded">ASPNETCORE_ENVIRONMENT</code> to
            <code class="font-mono text-xs bg-amber-100 dark:bg-amber-900/40 px-1.5 py-0.5 rounded">Development</code> and restart the app.
        </p>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
