@page "/"

<PageTitle>Home</PageTitle>

<!-- Hero section -->
<div class="py-10 md:py-14">
    <div class="max-w-2xl">
        <span class="inline-block px-3 py-1 text-xs font-semibold bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 rounded-full mb-4 tracking-wide uppercase">
            Blazor + Tailwind CSS v4
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-4 leading-tight">
            Hello, world!
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 mb-8 leading-relaxed">
            Welcome to a modern Blazor Server application styled with Tailwind CSS v4.
            Explore interactive components, responsive layouts, and dark mode support.
        </p>
        <div class="flex flex-wrap gap-3">
            <a href="/counter"
               class="btn-primary inline-flex items-center gap-2 px-5 py-2.5 font-semibold rounded-lg transition-colors">
                Try Counter
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </a>
            <a href="/weather"
               class="inline-flex items-center gap-2 px-5 py-2.5 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 font-semibold rounded-lg transition-colors">
                View Weather
            </a>
        </div>
    </div>
</div>

<!-- Feature cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5 mt-4">

    <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-600 dark:text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Tailwind CSS v4</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
            CSS-first configuration with utility-first styling, responsive breakpoints, and dark mode variants.
        </p>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Interactive Server</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
            Real-time two-way UI updates via a persistent WebSocket connection — no page reloads required.
        </p>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-sky-100 dark:bg-sky-900/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-600 dark:text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Dark Mode</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
            System-aware theme detection with manual toggle. Preference is saved to localStorage automatically.
        </p>
    </div>

</div>
