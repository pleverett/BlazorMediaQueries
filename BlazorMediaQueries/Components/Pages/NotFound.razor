@page "/not-found"
@layout MainLayout

<PageTitle>404 — Not Found</PageTitle>

<div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="text-8xl font-black text-slate-200 dark:text-slate-700 mb-2 leading-none select-none">404</div>
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Page Not Found</h1>
    <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-sm">
        Sorry, the content you are looking for doesn't exist or may have been moved.
    </p>
    <a href="/"
       class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-semibold rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
    </a>
</div>