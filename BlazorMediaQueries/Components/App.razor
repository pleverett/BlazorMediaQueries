<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["css/tailwind.output.css"]" />
    <link rel="stylesheet" href="@Assets["css/themes.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BlazorMediaQueries.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
    <script>
        // Apply dark mode and palette before first render to prevent flash
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            }
            const palette = localStorage.getItem('palette') || 'default';
            document.documentElement.dataset.palette = palette;
        })();
        window.darkMode = {
            isDark: () => document.documentElement.classList.contains('dark'),
            set: (isDark) => {
                if (isDark) {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                }
            }
        };
        window.palette = {
            get: () => document.documentElement.dataset.palette || 'default',
            set: (name) => {
                document.documentElement.dataset.palette = name;
                localStorage.setItem('palette', name);
            }
        };
    </script>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
